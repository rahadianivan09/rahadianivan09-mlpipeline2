# Prometheus scrape configuration
# Target: TensorFlow Serving metrics endpoint

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'tfserving-bank-deposit'
    metrics_path: '/monitoring/prometheus/metrics'
    scheme: https
    static_configs:
      - targets: ['rahadianivan09-bank-deposit-prediction.hf.space']
